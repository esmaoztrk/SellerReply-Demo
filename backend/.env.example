# Database Configuration
DB_HOST=localhost
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_NAME=your_database_name
DB_PORT=5432

# Server Configuration
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database Pool Settings
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# Security
TEMPORARY_API_KEY=replace_with_temporary_api_key
JWT_SECRET=replace_with_strong_jwt_secret
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret

# Encryption Keys (32 bytes hex)
PUBLIC_ENCRYPTION_KEY=replace_with_32_byte_hex_public_key
PRIVATE_ENCRYPTION_KEY=replace_with_32_byte_hex_private_key
ENCRYPTION_KEY=replace_with_32_byte_hex_encryption_key

# Logging
LOG_LEVEL=debug

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Cache Settings
CACHE_TTL=3600

# Timeout Settings (in milliseconds)
API_TIMEOUT=5000
DB_TIMEOUT=10000

# Client URL
CLIENT_URL=http://localhost:5173

# SMTP Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=no-reply@example.com

OPENAI_API_KEY=replace_with_openai_api_key
